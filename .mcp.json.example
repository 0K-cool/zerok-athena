{
  "mcpServers": {
    "athena-knowledge-base": {
      "command": "python3",
      "args": ["path/to/vex-rag/mcp_server/vex_kb_server.py"],
      "env": {
        "RAG_CONFIG": "./vex-rag.yml",
        "PYTHONPATH": "path/to/vex-rag"
      },
      "description": "ATHENA Pentest Knowledge Base"
    },
    "kali_external": {
      "command": "python3",
      "args": ["path/to/mcp-kali-linux/mcp_server.py", "--server", "http://your-kali-host:5000/"],
      "description": "Kali Linux — External pentesting"
    },
    "kali_internal": {
      "command": "python3",
      "args": ["path/to/mcp-kali-linux/mcp_server.py", "--server", "http://your-internal-kali:5000/"],
      "env": {
        "KALI_API_KEY": ""
      },
      "description": "Kali Linux — Internal pentesting"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--browser", "chromium", "--headless"],
      "description": "Playwright browser automation"
    },
    "athena-neo4j": {
      "command": "python3",
      "args": ["mcp-servers/neo4j-mcp/server.py"],
      "env": {
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASS": ""
      },
      "description": "ATHENA Knowledge Graph — Neo4j"
    }
  }
}
