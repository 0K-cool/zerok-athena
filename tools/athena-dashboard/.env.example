# 0K ATHENA Dashboard — Environment Configuration
# ================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run ./start.sh — the first-run wizard will generate .env for you.
# Environment variables always override .env file values.

# ── Neo4j Graph Database ──
# Required for persistent storage of findings, attack graphs, and events.
# Without Neo4j, data is stored in-memory only (lost on restart).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=

# ── Kali Backend (External) ──
# Public-facing URL for the Kali tool server.
KALI_EXTERNAL_URL=http://localhost:5000

# ── Kali Backend (Internal) ──
# Private network URL (ZeroTier, LAN, etc). Leave empty to skip.
KALI_INTERNAL_URL=

# ── Kali API Key ──
# Optional API key for authenticated Kali backend access.
KALI_API_KEY=

# ── Graphiti Cross-Session Memory ──
# Enables temporal knowledge graph for cross-engagement intelligence.
# Requires Anthropic API key (for entity extraction) and OpenAI API key
# (for embeddings — Anthropic does not offer an embeddings API).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GRAPHITI_LLM_MODEL=claude-haiku-4-5

# ── Langfuse LLM Observability ──
# Optional. Enables LLM tracing, cost tracking, and prompt analytics.
# Requires a running Langfuse instance (see docker/ for Docker Compose setup).
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
