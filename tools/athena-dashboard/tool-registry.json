    "endpoint": "/api/command",
    "command_template": "curl -sf --get --data-urlencode 'keywordSearch={keyword}' 'https://services.nvd.nist.gov/rest/json/cves/2.0?resultsPerPage=10'",
    "timeout": 20,
    "backends": ["external", "internal"],
    "category": "enrichment",
    "params": {
      "keyword": {"type": "string", "required": true, "description": "Service+version keyword (e.g. 'Apache 2.4.58', 'OpenSSH 8.9')"},
