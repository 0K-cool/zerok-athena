    "params": {
      "target": {"type": "string", "required": true, "description": "Target URL or IP"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra nikto flags"}
    }
  },

  "nuclei_scan": {
    "display_name": "Nuclei Vulnerability Scanner",
    "endpoint": "/api/command",
    "command_template": "nuclei -l {input_file} -jsonl -severity {severity}",
    "timeout": 900,
    "backends": ["external", "internal"],
    "category": "vuln",
    "params": {
      "targets": {"type": "list", "required": true, "description": "List of target URLs"},
      "severity": {"type": "string", "required": false, "default": "critical,high,medium", "description": "Severity filter"},
      "templates": {"type": "string", "required": false, "default": "", "description": "Specific template path or tag"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra nuclei flags"}
    }
  },

  "sqlmap_scan": {
    "display_name": "SQLMap Injection Tester",
    "endpoint": "/api/tools/sqlmap",
    "timeout": 600,
    "backends": ["external", "internal"],
    "category": "exploit",
    "hitl_required": true,
    "params": {
      "url": {"type": "string", "required": true, "description": "Target URL with injectable parameter"},
      "data": {"type": "string", "required": false, "default": "", "description": "POST data string"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra sqlmap flags (e.g. --technique=B --risk=1)"}
    }
  },

  "metasploit_run": {
    "display_name": "Metasploit Module Runner",
    "endpoint": "/api/tools/metasploit",
    "timeout": 600,
