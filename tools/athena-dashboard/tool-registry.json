    }
  },

  "packetstorm_search": {
    "display_name": "PacketStorm Exploit Search (Internet)",
    "endpoint": "/api/command",
    "command_template": "curl -sf --get --data-urlencode 'q={keyword}' 'https://packetstormsecurity.com/search/' | grep -oP '(?<=<a href=\"/files/)[^\"]+' | head -10",
    "timeout": 15,
    "backends": ["external", "internal"],
    "category": "enrichment",
    "params": {
      "keyword": {"type": "string", "required": true, "description": "Service+version keyword (e.g. 'Apache 2.4.58')"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra flags"}
    }
  },

  "_phase_e_comment": "Phase E: Web App Testing & Attack Path Chaining tools",

