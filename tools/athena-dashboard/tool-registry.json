{
  "_meta": {
    "version": "1.0.0",
    "description": "ATHENA tool registry. Add new tools here — no code changes needed.",
    "docs": "Each tool needs: display_name, endpoint, timeout, backends, category, params.",
    "notes": "Tools without a dedicated Flask endpoint use /api/command with command_template."
  },

  "nmap_scan": {
    "display_name": "Nmap Port Scanner",
    "endpoint": "/api/command",
    "command_template": "nmap {scan_type} {target}",
    "flag_notes": "Pass NSE scripts via additional_args, e.g. '--script=vuln' or '--script=http-headers,smb-os-discovery'. Ports go in additional_args too: '-p 80,443'.",
    "timeout": 300,
    "backends": ["external", "internal"],
    "category": "recon",
    "params": {
      "target": {"type": "string", "required": true, "description": "Target IP/CIDR/hostname"},
      "scan_type": {"type": "string", "required": false, "default": "-sV", "description": "Nmap scan type flags (e.g. -sV, -sS, -A)"},
      "ports": {"type": "string", "required": false, "default": "", "description": "Port specification (e.g. 1-1000, 80,443)"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra nmap flags including NSE scripts (e.g. --script=vuln, --script=http-headers)"}
    }
  },

  "naabu_scan": {
    "display_name": "Naabu Fast Port Scanner",
    "endpoint": "/api/command",
    "command_template": "PATH=$PATH:$HOME/go/bin:/usr/local/go/binnaabu -host {target} -json -rate 3000 -c 50 -retries 2 -warm-up-time 1",
    "timeout": 120,
    "backends": ["external", "internal"],
    "category": "recon",
    "params": {
      "target": {"type": "string", "required": true, "description": "Target IP/CIDR/hostname"},
      "ports": {"type": "string", "required": false, "default": "", "description": "Port specification"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra naabu flags"}
    }
  },

  "httpx_probe": {
    "display_name": "Httpx Web Prober",
    "endpoint": "/api/command",
    "command_template": "httpx -l {input_file} -json -tech-detect -status-code -title",
    "timeout": 300,
    "backends": ["external", "internal"],
    "category": "recon",
    "params": {
      "targets": {"type": "list", "required": true, "description": "List of URLs/hosts to probe"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra httpx flags"}
    }
  },

  "gobuster_scan": {
    "display_name": "Gobuster Directory Scanner",
    "endpoint": "/api/tools/gobuster",
    "timeout": 300,
    "backends": ["external", "internal"],
    "category": "web",
    "unsupported_flags": ["-wildcard", "--wildcard"],
    "flag_notes": "Do NOT use -wildcard or --wildcard (removed in modern gobuster). Use --no-error to suppress DNS errors instead.",
    "params": {
      "url": {"type": "string", "required": true, "description": "Target URL"},
      "mode": {"type": "string", "required": false, "default": "dir", "description": "Gobuster mode (dir, dns, vhost)"},
      "wordlist": {"type": "string", "required": false, "default": "/usr/share/wordlists/dirb/common.txt", "description": "Wordlist path"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra gobuster flags. Do NOT use -wildcard (unsupported)."}
    }
  },

  "nikto_scan": {
    "display_name": "Nikto Web Vulnerability Scanner",
    "endpoint": "/api/tools/nikto",
    "timeout": 600,
    "backends": ["external", "internal"],
    "category": "web",
    "params": {
      "target": {"type": "string", "required": true, "description": "Target URL or IP"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra nikto flags"}
    }
  },

  "nuclei_scan": {
    "display_name": "Nuclei Vulnerability Scanner",
    "endpoint": "/api/command",
    "command_template": "nuclei -l {input_file} -jsonl -severity {severity}",
    "timeout": 900,
    "backends": ["external", "internal"],
    "category": "vuln",
    "params": {
      "targets": {"type": "list", "required": true, "description": "List of target URLs"},
      "severity": {"type": "string", "required": false, "default": "critical,high,medium", "description": "Severity filter"},
      "templates": {"type": "string", "required": false, "default": "", "description": "Specific template path or tag"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra nuclei flags"}
    }
  },

  "sqlmap_scan": {
    "display_name": "SQLMap Injection Tester",
    "endpoint": "/api/tools/sqlmap",
    "timeout": 600,
    "backends": ["external", "internal"],
    "category": "exploit",
    "hitl_required": true,
    "unsupported_flags": ["--ssl-cert"],
    "flag_notes": "Do NOT use --ssl-cert (unsupported in sqlmap <=1.10.x). Use --force-ssl for HTTPS targets instead.",
    "params": {
      "url": {"type": "string", "required": true, "description": "Target URL with injectable parameter"},
      "data": {"type": "string", "required": false, "default": "", "description": "POST data string"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra sqlmap flags (e.g. --technique=B --risk=1). Do NOT use --ssl-cert (unsupported); use --force-ssl for HTTPS."}
    }
  },

