    "endpoint": "/api/command",
    "command_template": "curl -sf -H \"Authorization: Bearer ${ATTACKERKB_KEY:-}\" 'https://api.attackerkb.com/v1/topics?name={cve_id}'",
    "timeout": 15,
    "backends": ["external", "internal"],
