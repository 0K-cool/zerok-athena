      "username_file": {"type": "string", "required": false, "default": "", "description": "Username wordlist path"},
      "password": {"type": "string", "required": false, "default": "", "description": "Single password"},
      "password_file": {"type": "string", "required": false, "default": "", "description": "Password wordlist path"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra hydra flags"}
    }
  },

