  "github_exploit_search": {
    "display_name": "GitHub Exploit Search (Internet)",
    "endpoint": "/api/command",
    "command_template": "curl -sf -H 'Accept: application/vnd.github.v3+json' --get --data-urlencode 'q={keyword} exploit OR poc OR cve' 'https://api.github.com/search/repositories?sort=updated&per_page=10'",
    "timeout": 15,
    "backends": ["external", "internal"],
    "category": "enrichment",
    "params": {
      "keyword": {"type": "string", "required": true, "description": "Service+version keyword (e.g. 'Apache 2.4.58', 'vsftpd 2.3.4')"},
