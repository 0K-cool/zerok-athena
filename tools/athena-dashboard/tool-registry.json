  "_phase_e_comment": "Phase E: Web App Testing & Attack Path Chaining tools",

  "ffuf_fuzz": {
    "display_name": "ffuf Web Fuzzer",
    "endpoint": "/api/command",
    "command_template": "ffuf -u {url}/FUZZ -w {wordlist} -mc 200,301,302,403 -o /tmp/ffuf-{run_id}.json -of json",
    "timeout": 300,
    "backends": ["external", "internal"],
    "category": "web",
    "params": {
      "url": {"type": "string", "required": true, "description": "Target URL (FUZZ keyword added automatically)"},
      "wordlist": {"type": "string", "required": false, "default": "/usr/share/wordlists/dirb/common.txt", "description": "Wordlist path"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra ffuf flags (e.g. -fc 404, -H 'Cookie: ...')"}
    }
  },

  "dalfox_xss": {
    "display_name": "Dalfox XSS Scanner",
    "endpoint": "/api/command",
    "command_template": "dalfox url {url} --silence --format json --timeout 10",
    "timeout": 300,
    "backends": ["external", "internal"],
    "category": "web",
    "hitl_required": true,
    "params": {
      "url": {"type": "string", "required": true, "description": "Target URL with parameter to test"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra dalfox flags (e.g. --cookie, --header)"}
    }
  },

