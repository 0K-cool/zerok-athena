  "searchsploit_search": {
    "display_name": "SearchSploit CVE Lookup",
    "endpoint": "/api/command",
    "command_template": "searchsploit --cve {cve_id} -j",
    "timeout": 30,
    "backends": ["external", "internal"],
    "category": "enrichment",
    "params": {
      "cve_id": {"type": "string", "required": true, "description": "CVE number without CVE- prefix (e.g. 2011-2523)"},
      "additional_args": {"type": "string", "required": false, "default": "", "description": "Extra searchsploit flags"}
    }
  },

  "searchsploit_version": {
    "display_name": "SearchSploit Version Lookup",
